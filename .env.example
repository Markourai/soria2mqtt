# .env — soria2mqtt configuration
# Copy this file to .env and fill in your values.

# --- Tuya device credentials ---
SORIA_DEVICE_ID=xxxxxxxxxxxx
SORIA_DEVICE_IP=yyyyyyyyyyyy
SORIA_LOCAL_KEY=zzzzzzzzzzz
SORIA_TUYA_VERSION=3.5

# --- MQTT broker ---
MQTT_HOST=192.168.1.x
MQTT_PORT=1883
MQTT_USER=
MQTT_PASSWORD=
MQTT_TLS=false

# --- Topics ---
MQTT_TOPIC_PREFIX=soria2mqtt
HA_DISCOVERY_PREFIX=homeassistant

# --- Behaviour ---
LOG_LEVEL=INFO           # DEBUG for verbose output
HEARTBEAT_DELAY=20       # seconds between keep-alive pings
